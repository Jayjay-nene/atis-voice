# ATIS Voice — Configuration
# Copiez ce fichier en .env et remplissez les valeurs.
# Ou lancez : python voice_command.py --setup

# Cle API Groq (gratuite) : https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Touche de declenchement (defaut : CapsLock)
HOTKEY_KEY=CapsLock

# Dossier pour les notes vocales (Alt+touche)
# Defaut : ~/Documents/ATIS-Voice-Notes
# NOTES_PATH=C:\Users\VotreNom\Documents\ATIS-Voice-Notes
